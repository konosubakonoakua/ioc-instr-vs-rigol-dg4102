  <widget type="action_button" version="3.0.0">
    <name>Reset All</name>
    <actions>
      <action type="write_pv">
        <description>Write PV</description>
        <pv_name>$(P):SYSTEM_PRESET</pv_name>
        <value>1</value>
      </action>
    </actions>
    <text>SYSTEM RESET</text>
    <x>1250</x>
    <y>60</y>
    <width>140</width>
    <tooltip>$(actions)</tooltip>
  </widget>
  <widget type="group" version="3.0.0">
    <name>Sweep/Burst</name>
    <x>48</x>
    <y>430</y>
    <width>620</width>
    <height>180</height>
    <widget type="bool_button" version="2.0.0">
      <name>S</name>
      <pv_name>$(P):CH1:SWEEP_STAT</pv_name>
      <x>10</x>
      <y>10</y>
      <off_label>SWEEP OFF</off_label>
      <on_label>SWEEP ON</on_label>
    </widget>
    <widget type="bool_button" version="2.0.0">
      <name>B</name>
      <pv_name>$(P):CH1:BURST_STAT</pv_name>
      <x>120</x>
      <y>10</y>
      <off_label>BURST OFF</off_label>
      <on_label>BURST ON</on_label>
    </widget>
    <widget type="label" version="2.0.0">
      <text>Time:</text>
      <x>10</x>
      <y>55</y>
    </widget>
    <widget type="spinner" version="2.0.0">
      <pv_name>$(P):CH1:SWEEP_TIME</pv_name>
      <x>60</x>
      <y>50</y>
    </widget>
    <widget type="label" version="2.0.0">
      <text>Start:</text>
      <x>220</x>
      <y>55</y>
    </widget>
    <widget type="spinner" version="2.0.0">
      <pv_name>$(P):CH1:SWEEP_START</pv_name>
      <x>270</x>
      <y>50</y>
    </widget>
    <widget type="label" version="2.0.0">
      <text>Stop:</text>
      <x>430</x>
      <y>55</y>
    </widget>
    <widget type="spinner" version="2.0.0">
      <pv_name>$(P):CH1:SWEEP_STOP</pv_name>
      <x>480</x>
      <y>50</y>
    </widget>
    <widget type="label" version="2.0.0">
      <text>B.Mode:</text>
      <x>10</x>
      <y>105</y>
    </widget>
    <widget type="combo" version="2.0.0">
      <pv_name>$(P):CH1:BURST_MODE</pv_name>
      <x>80</x>
      <y>100</y>
    </widget>
    <widget type="label" version="2.0.0">
      <text>Cycles:</text>
      <x>220</x>
      <y>105</y>
    </widget>
    <widget type="spinner" version="2.0.0">
      <pv_name>$(P):CH1:BURST_CYCLES</pv_name>
      <x>280</x>
      <y>100</y>
    </widget>
  </widget>

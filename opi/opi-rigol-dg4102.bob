<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>Rigol DG4102 Control</name>
  <macros>
    <P>DG4102</P>
  </macros>
  <width>1400</width>
  <height>900</height>
  <widget type="label" version="2.0.0">
    <name>Title</name>
    <text>Rigol DG4102 Dual-Channel Waveform Generator (Extended)</text>
    <width>1400</width>
    <height>50</height>
    <font>
      <font name="Header 1" family="Liberation Sans" style="BOLD" size="22.0">
      </font>
    </font>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>IDN</name>
    <pv_name>$(P):IDN</pv_name>
    <x>30</x>
    <y>60</y>
    <width>1000</width>
    <height>30</height>
    <format>6</format>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>Status</name>
    <pv_name>$(P):COMM_STATUS</pv_name>
    <x>1050</x>
    <y>60</y>
    <width>180</width>
    <height>30</height>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
  </widget>
  <widget type="group" version="3.0.0">
    <name>Channel 1</name>
    <x>20</x>
    <y>110</y>
    <width>660</width>
    <height>630</height>
    <widget type="bool_button" version="2.0.0">
      <name>CH1_OUT</name>
      <pv_name>$(P):CH1:OUTPUT</pv_name>
      <x>10</x>
      <y>10</y>
      <width>80</width>
    </widget>
    <widget type="label" version="2.0.0">
      <text>Func:</text>
      <x>100</x>
      <y>15</y>
      <width>50</width>
    </widget>
    <widget type="combo" version="2.0.0">
      <pv_name>$(P):CH1:FUNC</pv_name>
      <x>160</x>
      <y>10</y>
      <width>120</width>
    </widget>
    <widget type="label" version="2.0.0">
      <text>Freq:</text>
      <x>10</x>
      <y>60</y>
      <width>50</width>
    </widget>
    <widget type="spinner" version="2.0.0">
      <pv_name>$(P):CH1:FREQ</pv_name>
      <x>70</x>
      <y>55</y>
      <width>150</width>
    </widget>
    <widget type="group" version="3.0.0">
      <name>Voltage Control</name>
      <x>10</x>
      <y>100</y>
      <height>182</height>
      <widget type="label" version="2.0.0">
        <text>Ampl:</text>
        <x>5</x>
        <y>10</y>
      </widget>
      <widget type="spinner" version="2.0.0">
        <pv_name>$(P):CH1:AMPL</pv_name>
        <x>70</x>
        <y>5</y>
      </widget>
      <widget type="label" version="2.0.0">
        <text>Offs:</text>
        <x>5</x>
        <y>45</y>
      </widget>
      <widget type="spinner" version="2.0.0">
        <pv_name>$(P):CH1:OFFSET</pv_name>
        <x>70</x>
        <y>40</y>
      </widget>
      <widget type="label" version="2.0.0">
        <text>High:</text>
        <x>5</x>
        <y>80</y>
        <font>
          <font family="" style="BOLD" size="14.0">
          </font>
        </font>
      </widget>
      <widget type="spinner" version="2.0.0">
        <pv_name>$(P):CH1:HIGH</pv_name>
        <x>70</x>
        <y>75</y>
      </widget>
      <widget type="label" version="2.0.0">
        <text>Low:</text>
        <x>5</x>
        <y>115</y>
        <font>
          <font family="" style="BOLD" size="14.0">
          </font>
        </font>
      </widget>
      <widget type="spinner" version="2.0.0">
        <pv_name>$(P):CH1:LOW</pv_name>
        <x>70</x>
        <y>110</y>
      </widget>
    </widget>
    <widget type="group" version="3.0.0">
      <name>Specifics</name>
      <x>322</x>
      <y>55</y>
      <width>308</width>
      <height>217</height>
      <widget type="label" version="2.0.0">
        <text>Duty Cycle:</text>
        <x>5</x>
        <y>10</y>
      </widget>
      <widget type="spinner" version="2.0.0">
        <pv_name>$(P):CH1:SQU_DCYC</pv_name>
        <x>120</x>
        <y>5</y>
      </widget>
      <widget type="label" version="2.0.0">
        <text>Symmetry:</text>
        <x>5</x>
        <y>45</y>
      </widget>
      <widget type="spinner" version="2.0.0">
        <pv_name>$(P):CH1:RAMP_SYMM</pv_name>
        <x>120</x>
        <y>40</y>
      </widget>
      <widget type="label" version="2.0.0">
        <text>Pulse Width:</text>
        <x>5</x>
        <y>80</y>
      </widget>
      <widget type="spinner" version="2.0.0">
        <pv_name>$(P):CH1:PULS_WIDT</pv_name>
        <x>120</x>
        <y>75</y>
      </widget>
      <widget type="label" version="2.0.0">
        <text>Lead Edge:</text>
        <x>5</x>
        <y>115</y>
      </widget>
      <widget type="spinner" version="2.0.0">
        <pv_name>$(P):CH1:PULS_LEAD</pv_name>
        <x>120</x>
        <y>110</y>
      </widget>
      <widget type="label" version="2.0.0">
        <text>Trail Edge:</text>
        <x>5</x>
        <y>150</y>
      </widget>
      <widget type="spinner" version="2.0.0">
        <pv_name>$(P):CH1:PULS_TRAI</pv_name>
        <x>120</x>
        <y>145</y>
      </widget>
    </widget>
    <widget type="group" version="3.0.0">
      <name>Modulation &amp; Trigger</name>
      <x>10</x>
      <y>492</y>
      <width>620</width>
      <height>100</height>
      <widget type="bool_button" version="2.0.0">
        <pv_name>$(P):CH1:MOD_STAT</pv_name>
        <x>10</x>
        <y>10</y>
        <off_label>MOD OFF</off_label>
        <on_label>MOD ON</on_label>
      </widget>
      <widget type="combo" version="2.0.0">
        <pv_name>$(P):CH1:MOD_TYP</pv_name>
        <x>120</x>
        <y>10</y>
      </widget>
      <widget type="label" version="2.0.0">
        <text>Trig Src:</text>
        <x>250</x>
        <y>15</y>
      </widget>
      <widget type="combo" version="2.0.0">
        <pv_name>$(P):CH1:TRIG_SOUR</pv_name>
        <x>320</x>
        <y>10</y>
      </widget>
      <widget type="action_button" version="3.0.0">
        <name>Manual Trigger</name>
        <actions>
          <action type="write_pv">
            <description>Write PV</description>
            <pv_name>$(P):CH1:TRIG_MANUAL</pv_name>
            <value>1</value>
          </action>
        </actions>
        <text>MANUAL TRIG</text>
        <x>450</x>
        <y>10</y>
        <width>120</width>
        <tooltip>$(actions)</tooltip>
      </widget>
    </widget>
  </widget>
  <widget type="group" version="3.0.0">
    <name>Channel 2</name>
    <x>700</x>
    <y>110</y>
    <width>660</width>

# Rigol DG4102 IOC Configuration Template
# Copy this file to .env and modify as needed before running deploy.sh

# --- Instrument Configuration ---
RIGOL_IP=21.21.25.2
RIGOL_PORT=5555
RIGOL_PREFIX=DG4102:

# --- Deployment Configuration ---
# Absolute path to the directory containing ioc.py
PROJECT_DIR=/home/rpi/epics/iocs/ioc-instr-vs-rigol-dg4102/ioc
# Absolute path to the Python executable (e.g. within a virtualenv)
PYTHON_BIN=/home/rpi/.virtualenvs/ioc/bin/python
# Linux user who will run the systemd service
SERVICE_USER=rpi

# --- EPICS Environment Configuration ---
# Unique port for this IOC's Channel Access server (avoid 5064/5065 if they are used)
EPICS_CA_SERVER_PORT=5080
# Unique port for this IOC's CA Repeater to avoid collision with others
EPICS_CA_REPEATER_PORT=5081

# Absolute path to the EPICS Base installation
EPICS_BASE=/home/rpi/EPICS/base-7.0.8.1

# Multi-IOC Coexistence: Point beacons and address list to the specific ports
EPICS_CAS_BEACON_ADDR_LIST=127.0.0.1:5081
EPICS_CA_ADDR_LIST=127.0.0.1:5080
